// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Models ────────────────────────────────────────────────────────────────────

model teams {
  id         Int       @id @default(autoincrement())
  first_name String?
  last_name  String?
  role       String?
  email      String?
  phone      String?
  age        Int?
  slack_id   String?
  is_boss    Boolean   @default(false)
  created_at DateTime  @default(now())

  // Relations
  users      users[]
  rapports   rapports[]
  task_comments  task_comments[]
  evaluations_given    Evaluation[] @relation("EvaluatorRelation")
  evaluations_received Evaluation[] @relation("EvaluatedRelation")
}

model users {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  role                String?
  team_id             Int?
  reset_token         String?   @unique
  reset_token_expires DateTime?

  // Relations
  team                teams?    @relation(fields: [team_id], references: [id])
}

model project {
  id          Int     @id @default(autoincrement())
  name        String?
  description String?
  icon        String?
  team_ids    Int[]

  // Relations
  tasks       tasks[]
  rapports    rapports[]
}

model tasks {
  id          Int       @id @default(autoincrement())
  title       String?
  description String?
  status      String?
  priority    String?
  project_id  Int?
  assigned_to Int[]
  due_date    DateTime? @db.Timestamptz
  created_at  DateTime  @default(now())
  reminder_sent Boolean @default(false)

  // Relations
  project     project?  @relation(fields: [project_id], references: [id])
  comments    task_comments[]
}

model task_comments {
  id         Int      @id @default(autoincrement())
  task_id    Int
  team_id    Int
  content    String
  created_at DateTime @default(now())

  task       tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  team       teams    @relation(fields: [team_id], references: [id])
}

model rapports {
  id                 Int       @id @default(autoincrement())
  team_id            Int?
  project_id         Int?
  work_built         String?
  working_built      String?
  validated_learning String?
  broken_features    String?
  needed_learning    String?
  tomorrow_build     String?
  extra_message      String?
  created_at         DateTime  @default(now())

  // Relations
  team               teams?    @relation(fields: [team_id], references: [id])
  project            project?  @relation(fields: [project_id], references: [id])
}

model Evaluation {
  id            Int      @id @default(autoincrement())
  evaluator_id  Int
  evaluated_id  Int
  report_date   DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  communication Int
  collaboration Int
  punctuality   Int
  comment       String?
  created_at    DateTime @default(now())

  evaluator     teams    @relation("EvaluatorRelation", fields: [evaluator_id], references: [id])
  evaluated     teams    @relation("EvaluatedRelation", fields: [evaluated_id], references: [id])

  @@unique([evaluator_id, evaluated_id, report_date])
  @@map("evaluations")
}
