// ═════════════════════════════════════════════════════════════════════════════
// SCHEMA V2 (final)
// ═════════════════════════════════════════════════════════════════════════════
//
// Conventions :
//   - PascalCase pour les modèles
//   - camelCase pour les champs (mappés en snake_case en DB via @map)
//   - cuid() au lieu d'autoincrement Int
//   - Énums DB-typés pour status/priority/role/etc.
//   - FK partout (fini les Int[] non-référencés)
//   - Audit log et notes pour la "mémoire projet"
//   - Une seule clé API table (ApiKey) avec hash bcrypt + scopes
//
// Historique : la migration V1 → V2 a été effectuée via le script
// `scripts/migrate-to-v2.ts` (commit b01bff0). Les modèles Legacy* qui
// cohabitaient pendant la transition ont été supprimés en Phase 2.F.
// ═════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identité ────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  PROJECT_MANAGER
  MEMBER
}

model Member {
  id        String   @id @default(cuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String?  @unique
  phone     String?
  age       Int?
  slackId   String?  @map("slack_id")
  role      Role     @default(MEMBER)
  isBoss    Boolean  @default(false) @map("is_boss")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  auth                Auth?
  projectMemberships  ProjectMember[]
  taskAssignments     TaskAssignment[]
  taskComments        TaskComment[]
  reports             Report[]
  expensesCreated     Expense[]        @relation("ExpenseCreator")
  evaluationsGiven    Evaluation[]     @relation("Evaluator")
  evaluationsReceived Evaluation[]     @relation("Evaluated")
  auditLogs           AuditLog[]

  @@map("members")
}

model Auth {
  id           String    @id @default(cuid())
  memberId     String    @unique @map("member_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  resetToken   String?   @unique @map("reset_token")
  resetExpires DateTime? @map("reset_expires")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("auths")
}

// ─── Projet ──────────────────────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?       @db.Text
  icon           String?
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime?     @db.Date @map("start_date")
  endDate        DateTime?     @db.Date @map("end_date")
  budgetAmount   Decimal?      @db.Decimal(14, 2) @map("budget_amount")
  budgetCurrency String        @default("XOF") @map("budget_currency")
  contractValue  Decimal?      @db.Decimal(14, 2) @map("contract_value")
  objectives     String?       @db.Text
  stakeholders   String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  members      ProjectMember[]
  deliverables Deliverable[]
  tasks        Task[]
  reports      Report[]
  expenses     Expense[]
  notes        ProjectNote[]

  @@map("projects")
}

model ProjectMember {
  projectId String   @map("project_id")
  memberId  String   @map("member_id")
  roleLabel String?  @map("role_label")
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([projectId, memberId])
  @@map("project_members")
}

enum Cadence {
  DAILY
  WEEKLY
  MONTHLY
  MILESTONE
}

enum DeliverableStatus {
  PLANNED
  IN_PROGRESS
  DONE
  MISSED
}

model Deliverable {
  id          String            @id @default(cuid())
  projectId   String            @map("project_id")
  parentId    String?           @map("parent_id")
  title       String
  description String?           @db.Text
  cadence     Cadence
  dueDate     DateTime          @db.Date @map("due_date")
  status      DeliverableStatus @default(PLANNED)
  completedAt DateTime?         @map("completed_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   Deliverable?  @relation("DeliverableHierarchy", fields: [parentId], references: [id])
  children Deliverable[] @relation("DeliverableHierarchy")
  tasks    Task[]

  @@index([projectId, dueDate])
  @@map("deliverables")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id             String     @id @default(cuid())
  projectId      String?    @map("project_id")
  deliverableId  String?    @map("deliverable_id")
  title          String
  description    String?    @db.Text
  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  startDate      DateTime?  @db.Timestamptz @map("start_date")
  dueDate        DateTime?  @db.Timestamptz @map("due_date")
  estimatedHours Decimal?   @db.Decimal(6, 2) @map("estimated_hours")
  actualHours    Decimal?   @db.Decimal(6, 2) @map("actual_hours")
  reminderSent   Boolean    @default(false) @map("reminder_sent")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliverable Deliverable?     @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  assignments TaskAssignment[]
  comments    TaskComment[]

  @@index([projectId])
  @@index([status, dueDate])
  @@map("tasks")
}

model TaskAssignment {
  taskId     String   @map("task_id")
  memberId   String   @map("member_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([taskId, memberId])
  @@map("task_assignments")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  memberId  String   @map("member_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

model Report {
  id             String   @id @default(cuid())
  memberId       String   @map("member_id")
  projectId      String?  @map("project_id")
  reportDate     DateTime @db.Date @map("report_date")
  workCompleted  String?  @db.Text @map("work_completed")
  inProgress     String?  @db.Text @map("in_progress")
  blockers       String?  @db.Text
  learnings      String?  @db.Text
  learningNeeded String?  @db.Text @map("learning_needed")
  tomorrowPlan   String?  @db.Text @map("tomorrow_plan")
  extraMessage   String?  @db.Text @map("extra_message")
  createdAt      DateTime @default(now()) @map("created_at")

  member  Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([memberId, reportDate, projectId])
  @@index([reportDate])
  @@index([projectId])
  @@map("reports")
}

model Evaluation {
  id            String   @id @default(cuid())
  evaluatorId   String   @map("evaluator_id")
  evaluatedId   String   @map("evaluated_id")
  reportDate    DateTime @db.Date @map("report_date")
  communication Int
  collaboration Int
  punctuality   Int
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  evaluator Member @relation("Evaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  evaluated Member @relation("Evaluated", fields: [evaluatedId], references: [id], onDelete: Cascade)

  @@unique([evaluatorId, evaluatedId, reportDate])
  @@map("evaluations")
}

enum ExpenseCategory {
  SALARY
  PURCHASE
  SUBCONTRACT
  TRAVEL
  SOFTWARE
  OTHER
}

model Expense {
  id          String          @id @default(cuid())
  projectId   String          @map("project_id")
  amount      Decimal         @db.Decimal(14, 2)
  currency    String          @default("XOF")
  category    ExpenseCategory
  description String?
  incurredAt  DateTime        @db.Date @map("incurred_at")
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy Member  @relation("ExpenseCreator", fields: [createdById], references: [id])

  @@index([projectId, incurredAt])
  @@map("expenses")
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  title     String
  body      Json
  tags      String[]
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, pinned, updatedAt])
  @@map("project_notes")
}

enum ActorType {
  HUMAN
  IA
  SYSTEM
}

model AuditLog {
  id        String    @id @default(cuid())
  actorId   String?   @map("actor_id")
  actorType ActorType @map("actor_type")
  action    String
  entity    String
  entityId  String    @map("entity_id")
  diff      Json?
  createdAt DateTime  @default(now()) @map("created_at")

  actor Member? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique @map("key_hash")
  prefix     String
  label      String?
  scopes     String[]
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  @@map("api_keys")
}

// ─── OAuth 2.1 (pour Claude.ai web Connectors) ──────────────────────────
//
// Un mini-serveur OAuth interne à Kazier. Un OAuthClient = une instance
// Claude.ai (créée par Dynamic Client Registration RFC 7591). Un Member
// consent une connexion via /oauth/authorize, ce qui crée un OAuthAuthCode
// éphémère ; Claude l'échange contre un OAuthToken (access + refresh) via
// POST /oauth/token. Le MCP server accepte l'access token en Bearer.

model OAuthClient {
  id          String   @id @default(cuid())
  clientId    String   @unique @map("client_id")
  clientName  String?  @map("client_name")
  redirectUris String[] @map("redirect_uris")
  // Dynamic Client Registration : pour les clients confidentiels on stocke
  // un hash du secret. Pour les clients publics (PKCE only) c'est null.
  clientSecretHash String? @map("client_secret_hash")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")

  authCodes OAuthAuthCode[]
  tokens    OAuthToken[]

  @@map("oauth_clients")
}

model OAuthAuthCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  clientId            String   @map("client_id")
  memberId            String   @map("member_id")
  redirectUri         String   @map("redirect_uri")
  codeChallenge       String   @map("code_challenge")
  codeChallengeMethod String   @map("code_challenge_method") // "S256"
  scope               String   // espace-séparé
  resource            String?  // RFC 8707 — canonical URI of the MCP server
  expiresAt           DateTime @map("expires_at")
  usedAt              DateTime? @map("used_at")
  createdAt           DateTime @default(now()) @map("created_at")

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([code])
  @@index([expiresAt])
  @@map("oauth_auth_codes")
}

model OAuthToken {
  id                String   @id @default(cuid())
  accessTokenHash   String   @unique @map("access_token_hash")
  refreshTokenHash  String?  @unique @map("refresh_token_hash")
  clientId          String   @map("client_id")
  memberId          String   @map("member_id")
  scope             String
  resource          String?  // RFC 8707 — bound audience
  accessExpiresAt   DateTime @map("access_expires_at")
  refreshExpiresAt  DateTime? @map("refresh_expires_at")
  revokedAt         DateTime? @map("revoked_at")
  lastUsedAt        DateTime? @map("last_used_at")
  createdAt         DateTime @default(now()) @map("created_at")

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([memberId])
  @@index([accessExpiresAt])
  @@map("oauth_tokens")
}
