# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kazier

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C0XXXXXXX
SLACK_BOSS_USER_ID=U0XXXXXXX

# Application URLs
NEXT_PUBLIC_FORM_URL=https://your-app-url.vercel.app

# NextAuth v5 (Auth.js) Configuration
AUTH_SECRET=your-secret-key-here-min-32-chars
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Email Configuration (Brevo SMTP for password reset)
BREVO_SMTP_USER=your-brevo-login-email@example.com
BREVO_SMTP_PASSWORD=your-brevo-smtp-key
