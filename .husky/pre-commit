# Run quality checks and auto-fix before commit
echo "🔍 Running quality checks with auto-fix..."

# 1. Auto-fix ESLint errors
echo "🔧 ESLint auto-fix..."
npm run lint:fix

# 2. Auto-format with Prettier
echo "💅 Prettier auto-format..."
npm run format

# 3. TypeScript check
echo "📘 TypeScript check..."
npm run type-check

# 4. Add auto-fixed files to commit
echo "📝 Adding auto-fixed files..."
git add -u

echo "✅ All quality checks passed!"
